# ==============================================================================
# ENVIRONMENT NODE SETUP
# ==============================================================================
NODE_ENV=development
PORT=8080
LOG_LEVEL=debug
# ==============================================================================
# PERSISTENT LOCAL DATABASE (MONGODB)
# ==============================================================================
MONGO_ROOT_USER=medadmin
MONGO_ROOT_PASSWORD=supersecure_db_password123
# Note: Points directly to the internal 'mongodb' container service name
MONGO_URI=mongodb://medadmin:supersecure_db_password123@localhost:27018/medication_platform?authSource=admin
# ==============================================================================
# ASYNC QUEUES & CACHING LAYER (REDIS & BULLMQ)
# ==============================================================================
# Note: Points directly to the internal 'redis' container service name
REDIS_URL=redis://redis:6379

# ==============================================================================
# SPLIT-TOKEN AUTHENTICATION SECRETS
# ==============================================================================
# Generate secure keys via terminal: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=bc82f3ef80dc4894392476d1e43bbcf5d1e2b5d4e892c90e1f7a3562a19c72e9
JWT_REFRESH_SECRET=8823f6d7ab71e4bf321096a605eddf83b28ee5390de2d103bf472ee91b05fc6a
COOKIE_SECRET=5e2bca810f723ea6df1b3e89cfcd922a

# ==============================================================================
# DATA PROTECTION: PHI AT-REST FIELD ENCRYPTION
# ==============================================================================
# Must be exactly 32-character hex string for AES-256-CBC field encryption
ENCRYPTION_KEY_AES256=1234567890abcdef1234567890abcdef

# ==============================================================================
# OBJECT STORAGE: AWS S3 SECURE IMAGE UPLOADS
# ==============================================================================
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUptYKMK7qYMAPIE/K7MDENG/bPxRfiCYEXAMPLE
AWS_S3_BUCKET_NAME=secure-med-packaging-images
AWS_REGION=us-east-1

# ==============================================================================
# ESCALATION PIPELINE: AWS SNS MULTI-CHANNEL MESSAGING
# ==============================================================================
AWS_SNS_REGION=us-east-1
AWS_SNS_SENDER_ID=MEDTRACK

# ==============================================================================
# PWA FRONTEND MECHANICS: WEB-PUSH NOTIFICATIONS
# ==============================================================================
# VAPID Keys for native browser push alerts

VAPID_SUBJECT=mailto:admin@medplatform.com
VAPID_PUBLIC_KEY=BF_dummy_vapid_public_key_string_replace_this_later_with_real_one
VAPID_PRIVATE_KEY=dummy_vapid_private_key_string_replace_this_later_with_real_one




RATE_LIMIT_GLOBAL_MAX=100
RATE_LIMIT_GLOBAL_WINDOW_MS=60000

RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW_MS=900000

RATE_LIMIT_MEDIA_MAX=20
RATE_LIMIT_MEDIA_WINDOW_MS=3600000



