{
  "name": "medimind",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "install:all": "npm install && npm --prefix backend install && npm --prefix frontend install && npm --prefix worker install",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:worker": "npm --prefix worker run dev",
    "dev": "concurrently \"npm:dev:backend\" \"npm:dev:frontend\" \"npm:dev:worker\"",
    "setup": "npm run install:all && npm run docker:up",
    "start": "npm run setup && npm run dev"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs"
}
